DATABASE_URL="file:./dev.db"
PORT=3001
# OBRIGATÓRIO em produção: gere um valor único e secreto (ex: openssl rand -hex 32).
# Em NODE_ENV=production o boot falha se estiver ausente ou no valor default.
JWT_SECRET=mude-esta-chave-em-producao-super-secreta
JWT_EXPIRES_IN=8h
NODE_ENV=development

# CORS: CSV de origens liberadas em produção. Em desenvolvimento qualquer origem
# é permitida (localhost:5173 etc.), então este valor só vale com NODE_ENV=production.
CORS_ALLOWED_ORIGINS=https://servicedeskcsp.com.br

# Auto-cadastro na tela de login (verificação por WhatsApp/OTP)
OTP_EXPIRES_MINUTES=10        # validade do código de verificação (minutos)
ALLOW_SELF_REGISTRATION=true  # 'false' desativa o cadastro público

# Seed do usuário admin padrão.
# Em produção, defina uma SEED_ADMIN_PASSWORD forte: o seed recusa a senha
# pública 'Admin@123' quando NODE_ENV=production.
SEED_ADMIN_EMAIL=admin@santapaula.com.br
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Administrador

# WhatsApp: 'mock' (apenas loga no console) ou 'evolution'
WHATSAPP_PROVIDER=mock
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-api
EVOLUTION_INSTANCE=nome-da-instancia

# Agente IA (Sofia) — Central de Comando. Proxy para a API admin do bot AGENTE CSP.
AGENT_ADMIN_URL=http://IP_DO_VPS:3001   # URL onde o bot está rodando
AGENT_ADMIN_SECRET=                     # mesmo valor do WEBHOOK_SECRET do bot

# Bot de suporte: recebe mensagens no WhatsApp e abre chamados automaticamente.
BOT_ENABLED=false                       # 'true' liga o recebimento via webhook
BOT_WEBHOOK_SECRET=                      # segredo na URL do webhook (gere um valor aleatório)
SUPPORT_EVOLUTION_INSTANCE=csp-suporte   # instância Evolution dedicada (vazio = reusa EVOLUTION_INSTANCE)
# Anthropic Claude — interpreta a mensagem e classifica o chamado
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Repositório de arquivos dos professores
UPLOAD_DIR=uploads          # pasta temporária do multer (apagada após upload)
MAX_FILE_SIZE_MB=100        # tamanho máximo por arquivo (MB)
STORAGE_PROVIDER=local      # 'local' (disco) | 'google-drive'

# Google Drive — OAuth2 (obrigatório quando STORAGE_PROVIDER=google-drive)
# Obtenha via: npx tsx scripts/google-drive-auth.ts
GOOGLE_DRIVE_ROOT_FOLDER_ID=ID_DA_PASTA_RAIZ_NO_DRIVE
GOOGLE_OAUTH_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-seu-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=1//seu-refresh-token
