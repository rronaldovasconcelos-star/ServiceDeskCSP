generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("USER") // ADMIN | USER
  phone         String?
  phoneVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ticketsRequested  Ticket[]               @relation("Requester")
  ticketsAssigned   Ticket[]               @relation("Assignee")
  history           TicketHistory[]
  supplyRequests    SupplyRequest[]        @relation("SupplyRequests")
  supplyHistory     SupplyRequestHistory[]
  files             File[]                 @relation("OwnerFiles")
  verificationCodes VerificationCode[]
  maintenancesResponsavel ScheduledMaintenance[] @relation("MaintenanceResponsavel")
  maintenancesCreated     ScheduledMaintenance[] @relation("MaintenanceCreator")
  materialReminders       MaterialReminder[]     @relation("ReminderCreator")
}

model BotSession {
  phone     String   @id // +55DDNNNNNNNNN (normalizado)
  state     String   @default("IDLE") // estado da máquina de conversa do bot de suporte
  data      String   @default("{}") // JSON: rascunho do chamado ou do cadastro em andamento
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String // bcrypt do código de 6 dígitos
  type      String   @default("REGISTER") // REGISTER | RESET
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId]) // garante um código ativo por usuário no nível do banco
}

model File {
  id           String   @id @default(cuid())
  originalName String
  storedName   String   // UUID + extensão (nome físico no disco)
  mimeType     String
  sizeBytes    Int
  storageKey   String   // "{ownerId}/{storedName}" — abstrai disco/S3
  folder       String?  // LEGADO — categoria livre dos arquivos antigos
  anoLetivo    String?  // ex "2026"
  segmento     String?  // "EI" | "FUND_I" | "FUND_II"
  serie        String?  // depende do segmento, ex "F1_3ANO", "EI_MATERNAL"
  etapa        String?  // "1" | "2" | "3"
  disciplina   String?  // ex "MATEMATICA"
  tipoMaterial String?  // ex "PROVA_AVALIATIVA"
  ownerId      String
  uploadedAt   DateTime @default(now())

  owner User @relation("OwnerFiles", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([anoLetivo, segmento, serie, etapa])
  @@index([disciplina])
  @@index([tipoMaterial])
}


model Ticket {
  id          String    @id @default(cuid())
  title       String
  description String
  category    String    // TI | MANUTENCAO | PEDAGOGICO | ADMINISTRATIVO | OUTROS
  urgency     String    // BAIXA | MEDIA | ALTA | URGENTE
  status      String    @default("ABERTO") // ABERTO | EM_ANDAMENTO | CONCLUIDO | CANCELADO
  requesterId String
  assigneeId  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  requester User            @relation("Requester", fields: [requesterId], references: [id])
  assignee  User?           @relation("Assignee", fields: [assigneeId], references: [id])
  history   TicketHistory[]
}

model SupplyItem {
  id          String   @id @default(cuid())
  name        String
  unit        String   // resma, unidade, caixa, litro, kg
  category    String   // PAPEL | TONER | LIMPEZA | INFORMATICA | OUTROS
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests SupplyRequest[]
}

model SupplyRequest {
  id          String   @id @default(cuid())
  itemId      String
  requesterId String
  quantity    Int
  urgency     String   @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  status      String   @default("PENDENTE") // PENDENTE | APROVADO | COMPRADO | ENTREGUE | CANCELADO
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item      SupplyItem             @relation(fields: [itemId], references: [id])
  requester User                   @relation("SupplyRequests", fields: [requesterId], references: [id])
  history   SupplyRequestHistory[]
}

model SupplyRequestHistory {
  id         String   @id @default(cuid())
  requestId  String
  authorId   String
  type       String   // COMMENT | STATUS_CHANGE
  message    String
  fromStatus String?
  toStatus   String?
  createdAt  DateTime @default(now())

  request SupplyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
}

model TicketHistory {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  type       String   // COMMENT | STATUS_CHANGE | ASSIGNMENT
  message    String
  fromStatus String?
  toStatus   String?
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
}

model ScheduledMaintenance {
  id            String   @id @default(cuid())
  name          String
  description   String
  urgency       String   @default("MEDIA")  // BAIXA | MEDIA | ALTA | URGENTE (vai pro chamado)
  recurrence    String   @default("NONE")   // NONE | DAILY | WEEKLY | MONTHLY | QUARTERLY | SEMIANNUAL | ANNUAL
  nextRunAt     DateTime                     // prazo de início da próxima ocorrência (gatilho)
  leadDays      Int      @default(0)         // antecedência do lembrete em dias (0 = sem lembrete)
  reminderSent  Boolean  @default(false)     // lembrete da ocorrência atual já enviado (reset ao reagendar)
  status        String   @default("ACTIVE")  // ACTIVE | PAUSED | DONE | CANCELLED
  lastTicketId  String?
  responsavelId String
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  responsavel User @relation("MaintenanceResponsavel", fields: [responsavelId], references: [id])
  createdBy   User @relation("MaintenanceCreator", fields: [createdById], references: [id])
}

model MaterialReminder {
  id           String   @id @default(cuid())
  name         String                        // rótulo interno (ex. "Provas 2ª etapa")
  messageExtra String?                        // texto livre adicional na mensagem
  recurrence   String   @default("MONTHLY")   // NONE | DAILY | WEEKLY | MONTHLY | QUARTERLY | SEMIANNUAL | ANNUAL
  nextRunAt    DateTime                        // quando disparar
  lastRunAt    DateTime?                       // início da janela "desde o último ciclo"
  status       String   @default("ACTIVE")    // ACTIVE | PAUSED | DONE | CANCELLED
  // Classificação-alvo (opcional; usada na mensagem e no "quem já enviou?")
  anoLetivo    String?
  segmento     String?
  serie        String?
  etapa        String?
  disciplina   String?
  tipoMaterial String?
  // Destinatários
  audience     String   @default("ALL")        // ALL | SELECTED
  recipientIds String?                          // JSON array de userIds quando SELECTED
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User @relation("ReminderCreator", fields: [createdById], references: [id])

  @@index([status, nextRunAt])
}
