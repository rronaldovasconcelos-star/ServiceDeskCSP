generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("USER") // ADMIN | USER
  phone         String?
  phoneVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ticketsRequested  Ticket[]               @relation("Requester")
  ticketsAssigned   Ticket[]               @relation("Assignee")
  history           TicketHistory[]
  supplyRequests    SupplyRequest[]        @relation("SupplyRequests")
  supplyHistory     SupplyRequestHistory[]
  files             File[]                 @relation("OwnerFiles")
  verificationCodes VerificationCode[]
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String // bcrypt do código de 6 dígitos
  type      String   @default("REGISTER") // REGISTER | RESET
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId]) // garante um código ativo por usuário no nível do banco
}

model File {
  id           String   @id @default(cuid())
  originalName String
  storedName   String   // UUID + extensão (nome físico no disco)
  mimeType     String
  sizeBytes    Int
  storageKey   String   // "{ownerId}/{storedName}" — abstrai disco/S3
  folder       String?  // categoria/pasta (ex: "Provas", "Planos de Aula")
  ownerId      String
  uploadedAt   DateTime @default(now())

  owner User @relation("OwnerFiles", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}


model Ticket {
  id          String    @id @default(cuid())
  title       String
  description String
  category    String    // TI | SUPRIMENTOS
  urgency     String    // BAIXA | MEDIA | ALTA | URGENTE
  status      String    @default("ABERTO") // ABERTO | EM_ANDAMENTO | CONCLUIDO | CANCELADO
  requesterId String
  assigneeId  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  requester User            @relation("Requester", fields: [requesterId], references: [id])
  assignee  User?           @relation("Assignee", fields: [assigneeId], references: [id])
  history   TicketHistory[]
}

model SupplyItem {
  id          String   @id @default(cuid())
  name        String
  unit        String   // resma, unidade, caixa, litro, kg
  category    String   // PAPEL | TONER | LIMPEZA | INFORMATICA | OUTROS
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests SupplyRequest[]
}

model SupplyRequest {
  id          String   @id @default(cuid())
  itemId      String
  requesterId String
  quantity    Int
  urgency     String   @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  status      String   @default("PENDENTE") // PENDENTE | APROVADO | COMPRADO | ENTREGUE | CANCELADO
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item      SupplyItem             @relation(fields: [itemId], references: [id])
  requester User                   @relation("SupplyRequests", fields: [requesterId], references: [id])
  history   SupplyRequestHistory[]
}

model SupplyRequestHistory {
  id         String   @id @default(cuid())
  requestId  String
  authorId   String
  type       String   // COMMENT | STATUS_CHANGE
  message    String
  fromStatus String?
  toStatus   String?
  createdAt  DateTime @default(now())

  request SupplyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
}

model TicketHistory {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  type       String   // COMMENT | STATUS_CHANGE | ASSIGNMENT
  message    String
  fromStatus String?
  toStatus   String?
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
}
