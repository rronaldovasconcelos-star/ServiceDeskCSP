# URL base da API (usa proxy do Vite em dev; em produção aponte para o backend)
VITE_API_URL=/api

# Login com Google — Client ID (tipo "Web") do Google Cloud Console.
# Autorize as origens http://localhost:5173 e https://servicedeskcsp.com.br.
# Sem este valor, o botão "Entrar com Google" simplesmente não aparece.
VITE_GOOGLE_CLIENT_ID=
