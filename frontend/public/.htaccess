# SPA (React Router / BrowserRouter) — reescreve rotas desconhecidas para index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Não reescrever arquivos/pastas que existem (assets com hash)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Qualquer outra rota → index.html (roteamento client-side)
  RewriteRule ^ index.html [L]
</IfModule>

# Cache: assets com hash (immutable) por 1 ano; index.html sempre revalidado
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpe?g|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Compressão
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
